{
  "openapi": "3.0.4",
  "info": {
    "title": "SmartJourneyPlanner.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Budget": {
      "post": {
        "tags": [
          "Budget"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TripBudget"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TripBudget"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TripBudget"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Budget/{tripId}": {
      "get": {
        "tags": [
          "Budget"
        ],
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Budget/add-expense/{tripId}": {
      "post": {
        "tags": [
          "Budget"
        ],
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Expense"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Expense"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Expense"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Budget/delete-expense/{tripId}/{expenseName}": {
      "delete": {
        "tags": [
          "Budget"
        ],
        "parameters": [
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expenseName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Expense": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "category": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "TripBudget": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "tripId": {
            "type": "string",
            "nullable": true
          },
          "totalSpent": {
            "type": "number",
            "format": "double"
          },
          "expenses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Expense"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Budget"
    }
  ]
}